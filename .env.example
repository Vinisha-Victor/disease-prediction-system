# Disease Prediction System Configuration

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# Frontend Configuration
FRONTEND_URL=http://localhost:8080

# Model Training Defaults
DEFAULT_GENERATIONS=20
DEFAULT_POPULATION=20
DEFAULT_MUTATION_RATE=0.12

# Optimization Algorithm Parameters
GA_MUTATION_RATE=0.12
PSO_W=0.6
PSO_C1=1.4
PSO_C2=1.4
DE_F=0.7
DE_CR=0.6

# Fitness Function Parameters
FITNESS_ALPHA=0.02
FITNESS_BETA=0.08
FITNESS_ACC_START=0.6
FITNESS_ACC_END=0.9

# Data Split Ratios
TRAIN_RATIO=0.6
VAL_RATIO=0.2
TEST_RATIO=0.2

# Model Configuration
RANDOM_FOREST_ESTIMATORS=200
LOGISTIC_REGRESSION_MAX_ITER=5000
SVM_KERNEL=rbf
NEURAL_NETWORK_LAYERS=(64, 32)
NEURAL_NETWORK_MAX_ITER=2000

# File Paths
SCALER_PATH=scaler.pkl
ENSEMBLE_MASK_PATH=ensemble_mask.pkl
MODELS_DIR=models/

# Dataset Configuration
SUPPORTED_DATASETS=breast_cancer,heart_disease,diabetes
DATASET_TARGET_COLUMNS=diagnosis,target,Outcome

# Logging
LOG_LEVEL=INFO
LOG_FILE=app.log
